# Copy this file to .env for local development.
# On Railway, set these in the project's Variables tab — do NOT commit the real values.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=1

# Gmail SMTP (use a Google App Password, not your real password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=3omarislam911@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here

# Admin login (the user account that can access /admin_dashboard)
ADMIN_USERNAME=Meerim
ADMIN_PASSWORD=change-me

# Database — on Railway with a SQLite volume use:
#   sqlite:////data/users.db
# Locally, leave unset to use instance/users.db
# DATABASE_URL=sqlite:////data/users.db

# Upload folder — on Railway with a volume use:
#   /data/uploads
# Locally, leave unset to use static/uploads
# UPLOAD_FOLDER=/data/uploads
